# =============================================
# FINORA ENVIRONMENT VARIABLES
# DO NOT commit this file with real values.
# Add these in Vercel Dashboard → Settings → Environment Variables
# =============================================

# SUPABASE (from supabase.com → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# AI KEYS — server-side only (Vercel functions)
# These NEVER go in VITE_ variables
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# META WHATSAPP (for Step 7 — add later)
# META_WHATSAPP_TOKEN=your_meta_token
# META_WHATSAPP_PHONE_ID=your_phone_id
